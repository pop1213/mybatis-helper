<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.pop1213.mybatishelper</id>
    <name>tiny mybatis helper</name>
    <vendor>pop1213</vendor>
    <description><![CDATA[
        <p><b>tiny mybatis helper</b> is a lightweight and high-performance IntelliJ IDEA plugin for MyBatis development.</p>
        <p><b>Key Features:</b></p>
        <ul>
            <li><b>Java to XML Navigation:</b> Quickly jump from a MyBatis Mapper Java interface method directly to its corresponding SQL statement tag in the XML mapper file.</li>
            <li><b>XML to Java Navigation:</b> Seamlessly jump back from XML statement tags (<code>&lt;select&gt;</code>, <code>&lt;insert&gt;</code>, <code>&lt;update&gt;</code>, <code>&lt;delete&gt;</code>) to their Java interface declarations.</li>
            <li><b>High Performance:</b> Built using optimized index-based lookup to ensure zero lag even in large codebases.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Mapper navigation (Java ↔ XML) -->
        <codeInsight.lineMarkerProvider language="JAVA" implementationClass="com.github.pop1213.mybatishelper.navigation.MapperJavaLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="XML" implementationClass="com.github.pop1213.mybatishelper.navigation.MapperXmlLineMarkerProvider"/>

        <!-- File-based index for fast XML namespace lookup -->
        <fileBasedIndex implementation="com.github.pop1213.mybatishelper.navigation.MyBatisNamespaceIndex"/>

        <!-- Console SQL filter: detects MyBatis SQL log pairs and adds a clickable hyperlink -->
        <consoleFilterProvider implementation="com.github.pop1213.mybatishelper.console.MyBatisSqlConsoleFilterProvider"/>

        <!-- Input filter: inserts 🪄 emoji after "Parameters:" before text is written to console -->
        <consoleInputFilterProvider implementation="com.github.pop1213.mybatishelper.console.MyBatisConsoleInputFilterProvider"/>

        <!-- Notification group for the SQL helper balloon -->
        <notificationGroup id="MyBatis SQL Helper"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>
</idea-plugin>
